<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://www.purebasic.com/namespace" version="1.0" creator="PureBasic 6.40">
  <section name="targets">
    <target name="byte_buffer_probe" enabled="1" default="1">
      <inputfile value="byte_buffer_probe.pb"/>
      <outputfile value="../../.build/examples/018-byte-buffer-framing/byte_buffer_probe"/>
      <executable value="../../.build/examples/018-byte-buffer-framing/byte_buffer_probe"/>
      <options thread="1" dpiaware="1" optimizer="0"/>
      <compiler version="PureBasic 6.40 - C Backend (MacOS X - arm64)"/>
      <format exe="console" cpu="1"/>
    </target>
  </section>
  <section name="files">
    <file name="byte_buffer_probe.pb"/>
  </section>
</project>
